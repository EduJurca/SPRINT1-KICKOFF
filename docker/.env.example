# Carsharing Platform - Environment Variables Template
# Copy this file to .env and update with your actual values
# Date: October 2025

# ============================================
# MariaDB Database Configuration
# ============================================
# Database host (use service name from docker-compose)
DB_HOST=mariadb

# Database port (default MariaDB port)
DB_PORT=3306

# Database name
DB_NAME=carsharing

# Database user (non-root user for application)
DB_USER=carsharing_user

# Database password (CHANGE THIS IN PRODUCTION!)
DB_PASSWORD=carsharing_pass

# MariaDB root password (CHANGE THIS IN PRODUCTION!)
MYSQL_ROOT_PASSWORD=root_password_change_me

# ============================================
# MongoDB Configuration
# ============================================
# MongoDB host (use service name from docker-compose)
MONGO_HOST=mongodb

# MongoDB port (default MongoDB port)
MONGO_PORT=27017

# MongoDB database name
MONGO_DB=carsharing

# MongoDB application user
MONGO_USER=carsharing_user

# MongoDB application password (CHANGE THIS IN PRODUCTION!)
MONGO_PASSWORD=carsharing_pass

# MongoDB root username (CHANGE THIS IN PRODUCTION!)
MONGO_ROOT_USER=admin

# MongoDB root password (CHANGE THIS IN PRODUCTION!)
MONGO_ROOT_PASSWORD=admin_password_change_me

# ============================================
# Application Configuration
# ============================================
# Application environment (development, staging, production)
APP_ENV=production

# JWT Secret Key for authentication (CHANGE THIS IN PRODUCTION!)
# Generate a strong random string (minimum 32 characters)
JWT_SECRET=your-secret-key-change-in-production-use-random-string

# JWT Token expiration time (in seconds)
# 3600 = 1 hour, 86400 = 24 hours
JWT_EXPIRATION=3600

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for CORS (comma-separated)
# Use * for development, specific domains for production
# Example: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=*

# ============================================
# Logging Configuration
# ============================================
# Log level (debug, info, warning, error, critical)
LOG_LEVEL=info

# ============================================
# Security Configuration
# ============================================
# Session lifetime (in seconds)
SESSION_LIFETIME=7200

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration (in seconds)
LOCKOUT_DURATION=900

# ============================================
# Email Configuration (Optional)
# ============================================
# SMTP server for sending emails
SMTP_HOST=smtp.example.com

# SMTP port (25, 465, 587)
SMTP_PORT=587

# SMTP username
SMTP_USER=noreply@carsharing.com

# SMTP password
SMTP_PASSWORD=smtp_password_change_me

# Email from address
EMAIL_FROM=noreply@carsharing.com

# Email from name
EMAIL_FROM_NAME=Carsharing Platform

# ============================================
# API Configuration
# ============================================
# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# API timeout (in seconds)
API_TIMEOUT=30

# ============================================
# File Upload Configuration
# ============================================
# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE=10

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# ============================================
# Map Configuration
# ============================================
# OpenStreetMap tile server URL
OSM_TILE_SERVER=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Default map center coordinates (latitude, longitude)
MAP_CENTER_LAT=40.4168
MAP_CENTER_LNG=-3.7038

# Default map zoom level
MAP_ZOOM_LEVEL=13

# ============================================
# Notes
# ============================================
# 1. Never commit the .env file to version control
# 2. Always use strong, unique passwords in production
# 3. Generate JWT_SECRET using: openssl rand -base64 32
# 4. Keep this file secure and restrict access
# 5. Update all default passwords before deployment
